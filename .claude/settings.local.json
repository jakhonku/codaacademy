{
  "permissions": {
    "allow": [
      "Bash(npx next *)",
      "Bash(git add *)",
      "Bash(git commit -m '@ *)",
      "PowerShell(git commit --amend -F \"$env:TEMP\\\\commitmsg.txt\"; if \\($?\\) { Remove-Item \"$env:TEMP\\\\commitmsg.txt\" })",
      "PowerShell(git push *)",
      "PowerShell(git add *)"
    ]
  }
}
